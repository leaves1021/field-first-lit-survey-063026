# Optional environment variables for literature search scripts

# NCBI recommends including an email when using E-utilities.
NCBI_EMAIL=your_email@example.com

# Optional. Without an API key, NCBI E-utilities should be kept at <= 3 requests/s.
NCBI_API_KEY=

# Optional. Semantic Scholar API key, if available.
SEMANTIC_SCHOLAR_API_KEY=
